@article{jlunghi_spreading_inprog,
abbr={Working Paper},
  title={"A Spreading Malaise: Manure Management, Air Pollution, and Hospital Admissions in Italy." - JMP},
  author={Lunghi, J.},
  abstract={Manure application is a common agricultural practice with environmental and public health risks. Using air quality and hospital discharge data from Lombardy, Italy, I estimate the causal impact of manure spreading on fine particulate matter (PM2.5) and study how short-term increases in pollution affect respiratory and cardiovascular hospitalisations, mortality, and treatment costs. Exploiting exogenous variation in spreading bans within a repeated event-study framework, I find that PM2.5 rises by 23.6% in the five days after bans are lifted. This increase is associated with a 1.04–1.145 rise in urgent hospitalisations and a 0.5–1.1 percentage point increase in in-hospital mortality, with no significant effect on cost per admission. The estimated annual financial burden ranges from 26.5 to 69.6 million euros. A policy simulation shows that incorporating PM targets into existing regulations yields only marginal reductions, highlighting the need for alternative mitigation strategies.
  },
  year={Ongoing},
  journal={},
  doi={},
  url={},
  note={(R&R at Journal of the Association of Environmental and Resource Economists)},
  selected={true}
}

